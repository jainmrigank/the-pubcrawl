# LLM for photo ingredient-identification and original-recipe drafting.
# Any OpenAI-compatible endpoint works. Without a key the app still runs:
# matching/browsing are unaffected, drafting falls back to an offline template.
LLM_API_KEY=
LLM_MODEL=gemini-3.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=45

# Bar nudges (web push). Generate a key pair once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# PUSH_SECRET guards /api/push/send; give the same value to the GitHub Action.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
PUSH_SECRET=

# Durable likes / kept drinks / push subscriptions (free Upstash Redis).
# Without these the server writes local JSON, which resets on every redeploy.
KV_REST_API_URL=
KV_REST_API_TOKEN=
